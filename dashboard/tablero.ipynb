import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import textwrap
from PIL import Image
import requests
from io import BytesIO

# --- ESTILO Y LIENZO ---
plt.rcParams['figure.facecolor'] = '#ffffff'
fig = plt.figure(figsize=(20, 25))
# Definimos 4 niveles de información
gs = fig.add_gridspec(4, 2, height_ratios=[0.1, 0.3, 1, 0.8], hspace=0.4, wspace=0.2)

# 1. TÍTULO PRINCIPAL
fig.suptitle('ESTRATEGIA DIGITAL: SUROESTE DE MÉXICO\nEquipo: AbejasAstutas | Proyecto HackODS', 
             fontsize=32, fontweight='bold', color='#1a5276', y=0.98)

# 2. HISTORIA (Storytelling sin Actos)
ax0 = fig.add_subplot(gs[1, :])
ax0.axis('off')
texto = (
    "En Chiapas, Guerrero y Oaxaca, la brecha digital no es solo técnica; es una barrera para el desarrollo humano. "
    "Mientras el norte del país avanza hacia la industria 4.0, el suroeste lucha por conectar a sus estudiantes. "
    "Este tablero demuestra que sin inversión en infraestructura, el derecho a la educación seguirá siendo un privilegio."
)
wrap_text = textwrap.fill(texto, width=100)
ax0.text(0.5, 0.5, wrap_text, fontsize=20, ha='center', va='center', style='italic',
         bbox=dict(facecolor='#f0f7fb', edgecolor='#3498db', boxstyle='round,pad=1.5'))

# 3. EL MAPA DE CONEVAL (Carga Forzada)
ax1 = fig.add_subplot(gs[2, 0])
url_mapa = "https://www.coneval.org.mx/Medicion/MP/Documents/Pobreza_Municipal_2020/Mapa_Pobreza_Municipal_2020.jpg"
try:
    headers = {'User-Agent': 'Mozilla/5.0'}
    r = requests.get(url_mapa, headers=headers, timeout=15)
    img = Image.open(BytesIO(r.content))
    ax1.imshow(img)
    ax1.set_title('ZONAS DE REZAGO SOCIAL (CONEVAL)', fontsize=18, fontweight='bold')
    ax1.axis('off')
except:
    ax1.text(0.5, 0.5, "Error de conexión.\nSube 'mapa.jpg' manualmente.", ha='center', va='center', fontsize=16)
    ax1.axis('off')

# 4. ACCESO A INTERNET (ENDUTIH)
ax2 = fig.add_subplot(gs[2, 1])
df_int = pd.DataFrame({
    'Estado': ['Nacional', 'Chiapas', 'Oaxaca', 'Guerrero'],
    'Internet %': [73.6, 50.7, 55.5, 58.9]
})
sns.barplot(data=df_int, x='Estado', y='Internet %', palette='Blues_d', ax=ax2)
ax2.set_title('DISPONIBILIDAD DE INTERNET', fontsize=18, fontweight='bold')
ax2.set_ylim(0, 100)

# 5. POBREZA (CONEVAL)
ax3 = fig.add_subplot(gs[3, 0])
sns.barplot(x=['Nacional', 'Chiapas', 'Oaxaca', 'Guerrero'], y=[36.3, 67.4, 58.4, 60.4], 
            palette='Reds_d', ax=ax3)
ax3.set_title('POBREZA MULTIDIMENSIONAL %', fontsize=18, fontweight='bold')

# 6. EDUCACIÓN (SIGED)
ax4 = fig.add_subplot(gs[3, 1])
niveles = ['Primaria', 'Secundaria', 'Media Sup.', 'Superior']
nac = [98, 92, 75, 45]
sur = [94, 85, 58, 22]
ax4.plot(niveles, nac, 'g-s', label='Nacional', linewidth=3)
ax4.plot(niveles, sur, 'r-o', label='Suroeste', linewidth=3)
ax4.set_title('FINALIZACIÓN DE ESTUDIOS', fontsize=18, fontweight='bold')
ax4.legend()
ax4.grid(True, alpha=0.2)

plt.show()
