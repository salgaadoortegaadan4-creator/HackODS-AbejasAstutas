import pandas as pd
import matplotlib.pyplot as plt

# Datos de conectividad
datos = {'Estado': ['Nacional', 'Chiapas', 'Oaxaca', 'Guerrero'],
         'Internet %': [73.6, 50.7, 55.5, 58.9]}
df = pd.DataFrame(datos)

# Gráfica
plt.bar(df['Estado'], df['Internet %'], color=['blue', 'red', 'orange', 'orange'])
plt.title('Brecha Digital: Suroeste vs Nacional')
plt.show()
